{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uxnan Desktop",
  "version": "0.0.6",
  "identifier": "dev.luisgamas.uxnandesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Uxnan Desktop",
        "width": 1480,
        "height": 920,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFMjdFQUFFRTBDRDE0Q0UKUldUT0ZNM2dydW9uemdBMmdQeW1SK2I1cmJXaXdTck1xMlNxL2ZHSVRWK0N3WXpEUDlVZlZXYTEK",
      "endpoints": [
        "https://github.com/luisgamas/uxnan/releases/download/desktop-updater-stable/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
