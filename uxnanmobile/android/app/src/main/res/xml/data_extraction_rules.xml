<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Never clone the Ed25519 identity or notification secret. -->
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml" />
        <exclude domain="sharedpref" path="FlutterSecureKeyStorage.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Device-to-device restore follows the same fresh-identity rule. -->
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml" />
        <exclude domain="sharedpref" path="FlutterSecureKeyStorage.xml" />
    </device-transfer>
</data-extraction-rules>
