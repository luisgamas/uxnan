<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Network: WebSocket transport (LAN/Tailscale/relay), REST pairing, FCM,
         and mDNS bridge discovery. Required for release builds (Flutter only
         auto-adds INTERNET to debug/profile). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- mDNS/DNS-SD bridge discovery (nsd / NsdManager). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- QR pairing scanner (mobile_scanner + permission_handler). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Composer voice dictation (speech_to_text). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <application
        android:label="Uxnan"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- FCM display defaults for notifications the system builds itself
             (a "notification" payload delivered while the app is backgrounded or
             killed, before Dart runs). Without these, FCM falls back to the full
             colour launcher icon, which Android renders as a white square in the
             status bar. The small icon is a white silhouette on transparency
             (ic_stat_uxnan, res/drawable-*/); notification_color tints it (and
             the app label) in the shade. The foreground path — built in Dart via
             flutter_local_notifications — sets the same icon/colour explicitly in
             PushNotificationService, so both paths look identical. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_uxnan" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <!-- Route FCM notifications to the app's high-importance channel (created
             in PushNotificationService) so background pushes match the foreground
             ones instead of landing on FCM's silent fallback channel. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="uxnan_turns" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
